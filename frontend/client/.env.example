# Backend base URL (no trailing slash). If unset, connexion démo locale sans appels HTTP.
# Express par défaut : port 3000
VITE_API_BASE_URL=http://localhost:3000

# Même secret que API_KEY_SIMULATION dans backend/.env — obligatoire si le backend a AUTH_DISABLED différent de true
# Exemple : VITE_API_KEY_SIMULATION=dev-simulation-key
# VITE_API_KEY_SIMULATION=
