NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Supabase (backend uniquement — jamais exposer au frontend)
# Copier ce fichier vers .env et remplir (dotenv charge .env, pas .env.example)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT ou clé API (selon choix d’auth)
# JWT_SECRET=

# Origines CORS (Vercel client + admin), séparées par des virgules
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
