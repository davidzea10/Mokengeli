NODE_ENV=development
# Chemin public (HTTPS, sans cert client) — hackathon / Vercel
PORT=3000

# Deuxième listener mTLS (cert client obligatoire) — désactivé par défaut
MTLS_ENABLED=false
MTLS_PORT=8443

LOG_LEVEL=debug

# Dossier des certificats (optionnel) — défaut : certs/ à la racine du dépôt
# CERTS_DIR=

# Supabase (backend uniquement — jamais exposer au frontend)
# Copier ce fichier vers .env et remplir (dotenv charge .env, pas .env.example)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Clé publique anon (Dashboard → API) — pour tests smoke Supabase côté script uniquement
SUPABASE_ANON_KEY=
# JWT Secret du projet (Dashboard → Settings → API → JWT Secret) — valide les access_token Auth
SUPABASE_JWT_SECRET=

# JWT ou clé API (selon choix d’auth)
AUTH_DISABLED=true
# JWT signés à la main / smoke local (optionnel si tu n’utilises que Supabase Auth)
JWT_SECRET=
API_KEY_SIMULATION=
API_KEY_ANALYST=

# Origines CORS (séparées par des virgules).
# Pour Vercel : remplacer par les 2 domaines réels (client/ + admin/).
# Ex: CORS_ORIGINS=https://frontend-client-xxx.vercel.app,https://frontend-admin-xxx.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Rate limiting (par défaut : 15 min / 100 requêtes)
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=

# Tests smoke avec Supabase Auth (npm run test:smoke + SMOKE_AUTH_MODE=supabase)
# SMOKE_SUPABASE_EMAIL_SIMULATION=
# SMOKE_SUPABASE_PASSWORD_SIMULATION=
# SMOKE_SUPABASE_EMAIL_ANALYSTE=
# SMOKE_SUPABASE_PASSWORD_ANALYSTE=
