NODE_ENV=development
# Chemin public (HTTPS, sans cert client) — hackathon / Vercel
PORT=3000

# Deuxième listener mTLS (cert client obligatoire) — désactivé par défaut
MTLS_ENABLED=false
MTLS_PORT=8443

LOG_LEVEL=debug

# Dossier des certificats — défaut : ../certs/ (Mokengeli/certs/) avec server.key + server.crt
# Sans ces fichiers : en NODE_ENV=development, le serveur démarre en HTTP sur PORT (OK pour le local).
# En prod sans fichiers certs dans le conteneur (ex. Render : TLS géré par la plateforme) : inutile si RENDER=true.
# Sinon : ALLOW_HTTP_WITHOUT_TLS=true
# CERTS_DIR=
# ALLOW_HTTP_WITHOUT_TLS=

# Supabase (backend uniquement — jamais exposer au frontend)
# Copier ce fichier vers .env et remplir (dotenv charge .env, pas .env.example)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Clé publique anon (Dashboard → API) — pour tests smoke Supabase côté script uniquement
SUPABASE_ANON_KEY=
# JWT Secret du projet (Dashboard → Settings → API → JWT Secret) — valide les access_token Auth
SUPABASE_JWT_SECRET=

# Auth API : par défaut **désactivée** (démo). Pour forcer JWT / clé API sur toutes les routes protégées :
# AUTH_REQUIRED=true
# (ou AUTH_DISABLED=false — équivalent si vous gériez l’ancien flag)
AUTH_DISABLED=true
# JWT signés à la main / smoke local (optionnel si tu n’utilises que Supabase Auth)
JWT_SECRET=
API_KEY_SIMULATION=
API_KEY_ANALYST=

# CORS : le backend envoie toujours Access-Control-Allow-Origin=* (pas de variable à configurer).

# Liste admin : taille max d’une page (pagination, défaut 1000, plafonné à 5000).
# ADMIN_MAX_PAGE_LIMIT=1000

# Rate limiting (par défaut : 15 min / 100 requêtes)
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=

# Tests smoke avec Supabase Auth (npm run test:smoke + SMOKE_AUTH_MODE=supabase)
# SMOKE_SUPABASE_EMAIL_SIMULATION=
# SMOKE_SUPABASE_PASSWORD_SIMULATION=
# SMOKE_SUPABASE_EMAIL_ANALYSTE=
# SMOKE_SUPABASE_PASSWORD_ANALYSTE=
