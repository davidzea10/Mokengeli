        "body": {
          "mode": "raw",
          "raw": "{\n  \"session_id\": \"{{sessionId}}\",\n  \"canal\": \"web\",\n  \"adresse_ip\": \"10.0.0.1\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/sessions",
        "description": "Étape 4.4 — après création ; exécuter d’abord « POST session (nouvelle) » pour remplir sessionId."
      }
