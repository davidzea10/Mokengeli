      }
    },
    {
      "name": "4.6 — Admin détail transaction",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200 ou 404\", function () { pm.expect([200,404]).to.include(pm.response.code); });",
              "if (pm.response.code === 200) { pm.test(\"detail\", function () { var d = pm.response.json().data; pm.expect(d).to.have.property(\"id\"); pm.expect(d).to.have.property(\"scores_evaluation\"); }); }"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/admin/transactions/{{transactionId}}",
        "description": "Étape 4.6 — détail audit (satellites + scores). Coller un UUID ou exécuter 4.5 avant pour remplir transactionId."
      }
    }
